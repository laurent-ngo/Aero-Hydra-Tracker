[Unit]
Description=Aero-Hydra Elevation API
After=network.target

[Service]
Type=simple
User=lngo
WorkingDirectory=/home/lngo/projects/aero-hydra/back/OpenSky/src
EnvironmentFile=/home/lngo/projects/aero-hydra/back/OpenSky/api.env
ExecStart=/home/lngo/projects/aero-hydra/.venv/bin/uvicorn elevation_api:app --host 0.0.0.0 --port 8011
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
